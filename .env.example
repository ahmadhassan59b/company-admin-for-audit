PORT=3000
APP_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3001
NODE_ENV=development

# Docker Compose / PostgreSQL
POSTGRES_DB=hubspot_audit_tool
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-postgres-password
POSTGRES_PORT=5432
BACKEND_PORT=3000
UI_PORT=3001
ADMIN_DASHBOARD_REQUIRE_AUTH=false

HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
# Local HubSpot OAuth callback. This exact URL must be added to your HubSpot app redirect URLs.
HUBSPOT_REDIRECT_URI=http://localhost:3000/auth/hubspot/callback
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hubspot_audit_tool

# Optional
INTERNAL_ACCOUNT_KEY=default-team
TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret
AUTH_JWT_SECRET=replace-with-a-different-long-random-secret
HUBSPOT_REQUIRED_SCOPES=crm.objects.contacts.read crm.objects.companies.read crm.objects.deals.read crm.schemas.contacts.read crm.schemas.companies.read crm.schemas.deals.read forms oauth
HUBSPOT_OPTIONAL_SCOPES=automation
GOOGLE_CLIENT_ID=
# Local email testing.
# Option 1: keep EMAIL_DEV_FALLBACK=true to log verification links in backend logs.
# Option 2: set EMAIL_DEV_FALLBACK=false and fill SMTP_* values, for example Mailtrap.
EMAIL_FROM=HubAudit <no-reply@local.test>
EMAIL_DEV_FALLBACK=true
SMTP_HOST=
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60

# Mailtrap sandbox example:
# EMAIL_DEV_FALLBACK=false
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=your-mailtrap-username
# SMTP_PASS=your-mailtrap-password

# Phase 3 (AI) - optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_PROVIDER=auto

# Phase 3 (AI) - OpenRouter / GPT-OSS
# Get an API key from OpenRouter, then set AI_PROVIDER=openrouter or leave auto.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=HubAudit
AI_PROMPT_MODE=compact
HUBSPOT_AUDIT_RECORD_LIMIT=300
AI_MAX_INPUT_CHARS=8000
AI_CACHE_TTL_SECONDS=3600
AI_BACKGROUND_QUEUE_CONCURRENCY=2
AI_COST_PER_1K_INPUT=0
AI_COST_PER_1K_OUTPUT=0
MONITORING_WINDOW_MS=300000
MONITORING_SLOW_REQUEST_MS=2000
MONITORING_ERROR_RATE_ALERT_THRESHOLD=0.1
MONITORING_MIN_REQUESTS_FOR_ALERT=25
MONITORING_ALERT_COOLDOWN_MS=300000
SECURITY_ISSUER_NAME=HubAudit

# Phase 3 (AI) - Optional local fallback (Ollama)
# Install Ollama and pull a model, e.g.: ollama pull gemma2:2b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:2b

# Optional (future / advanced). Leave commented for MVP compatibility:
# HUBSPOT_REQUIRED_SCOPES=crm.objects.contacts.read crm.objects.companies.read crm.objects.deals.read crm.schemas.contacts.read crm.schemas.companies.read crm.schemas.deals.read forms oauth
# HUBSPOT_OPTIONAL_SCOPES=automation
ACCOUNT_LABEL_FORMAT=dash
